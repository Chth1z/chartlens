EYES_OPENAI_API_KEY=
EYES_OPENAI_AUTH_MODE=auto
EYES_OPENAI_STANDARD_MODEL=gpt-5.4-mini
EYES_OPENAI_THOROUGH_MODEL=gpt-5.5
EYES_DATABASE_URL=sqlite:///./storage/eyes.sqlite3
EYES_REDIS_URL=redis://localhost:6379/0
EYES_STORAGE_DIR=./storage
EYES_MODEL_MODE=standard
EYES_OCR_PROFILE=accurate
EYES_LAYOUT_PROFILE=chinese_inpatient_v1
EYES_SYNC_PIPELINE=false
EYES_CASE_WORKERS=1
EYES_OCR_PAGE_WORKERS=2
EYES_LLM_WORKERS=1
EYES_LLM_CASE_CONTEXT_BUDGET=3200
VITE_API_BASE=

# Optional OAuth2/OIDC login. Leave disabled for local single-user MVP use.
EYES_OAUTH_ENABLED=false
# chatgpt: built-in local ChatGPT/Codex PKCE login. oidc: institution/provider OAuth2/OIDC.
EYES_OAUTH_PROVIDER=chatgpt
EYES_OAUTH_CLIENT_ID=
EYES_OAUTH_CLIENT_SECRET=
EYES_OAUTH_AUTHORIZATION_URL=
EYES_OAUTH_TOKEN_URL=
EYES_OAUTH_USERINFO_URL=
EYES_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/callback
EYES_OAUTH_SCOPES=openid email profile
EYES_OAUTH_ALLOWED_EMAIL_DOMAINS=
EYES_OAUTH_SESSION_SECRET=change-me-for-production
EYES_CHATGPT_TOKEN_CACHE_PATH=./storage/auth/chatgpt_tokens.json
EYES_CHATGPT_CODEX_RESPONSES_URL=https://chatgpt.com/backend-api/codex/responses
