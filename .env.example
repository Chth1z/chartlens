CHARTLENS_OPENAI_API_KEY=
CHARTLENS_OPENAI_AUTH_MODE=auto
CHARTLENS_OPENAI_STANDARD_MODEL=gpt-5.4-mini
CHARTLENS_OPENAI_THOROUGH_MODEL=gpt-5.5
CHARTLENS_DATABASE_URL=sqlite:///./storage/chartlens.sqlite3
CHARTLENS_STORAGE_DIR=./storage
CHARTLENS_MODEL_MODE=standard
CHARTLENS_OCR_PROFILE=accurate
CHARTLENS_LAYOUT_PROFILE=chinese_inpatient_v1
CHARTLENS_SYNC_PIPELINE=false
CHARTLENS_CASE_WORKERS=1
CHARTLENS_OCR_PAGE_WORKERS=2
CHARTLENS_LLM_WORKERS=1
CHARTLENS_LLM_CASE_CONTEXT_BUDGET=3200
VITE_API_BASE=

# Optional OAuth2/OIDC login. Leave disabled for local single-user MVP use.
CHARTLENS_OAUTH_ENABLED=false
# chatgpt: built-in local ChatGPT/Codex PKCE login. oidc: institution/provider OAuth2/OIDC.
CHARTLENS_OAUTH_PROVIDER=chatgpt
CHARTLENS_OAUTH_CLIENT_ID=
CHARTLENS_OAUTH_CLIENT_SECRET=
CHARTLENS_OAUTH_AUTHORIZATION_URL=
CHARTLENS_OAUTH_TOKEN_URL=
CHARTLENS_OAUTH_USERINFO_URL=
CHARTLENS_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/callback
CHARTLENS_OAUTH_SCOPES=openid email profile
CHARTLENS_OAUTH_ALLOWED_EMAIL_DOMAINS=
CHARTLENS_OAUTH_SESSION_SECRET=change-me-for-production
CHARTLENS_CHATGPT_TOKEN_CACHE_PATH=./storage/auth/chatgpt_tokens.json
CHARTLENS_CHATGPT_CODEX_RESPONSES_URL=https://chatgpt.com/backend-api/codex/responses
